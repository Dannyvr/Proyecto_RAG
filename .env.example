# =========================================================
# Sistema RAG Avanzado - Variables de Entorno
# Copia este archivo como ".env" en la carpeta backend/ y completa los valores.
# NUNCA subas el archivo ".env" a un repositorio público.
# =========================================================

# ---------------------------------------------------------
# GOOGLE GEMINI (Proveedor LLM)
# Obtén tu API key en: https://aistudio.google.com/app/apikey
# ---------------------------------------------------------
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash

# ---------------------------------------------------------
# CONFIGURACIÓN DEL SERVIDOR
# ---------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# ---------------------------------------------------------
# CONFIGURACIÓN DEL VECTOR STORE (FAISS)
# ---------------------------------------------------------
VECTOR_STORE_PATH=./faiss_index
EMBEDDINGS_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ---------------------------------------------------------
# CONFIGURACIÓN RAG
# ---------------------------------------------------------
RETRIEVAL_TOP_K=4
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ---------------------------------------------------------
# CORS - Orígenes permitidos (separados por coma)
# ---------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
