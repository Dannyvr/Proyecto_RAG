# =========================================================
# Sistema RAG Avanzado - Variables de Entorno
# Copia este archivo como ".env" y completa los valores.
# NUNCA subas el archivo ".env" a un repositorio público.
# =========================================================

# ---------------------------------------------------------
# PROVEEDOR LLM ACTIVO
# Valores posibles: "gemini" | "azure"
# ---------------------------------------------------------
LLM_PROVIDER=gemini

# ---------------------------------------------------------
# OPCIÓN 1: Google Gemini (Google AI Studio)
# Obtén tu API key en: https://aistudio.google.com/app/apikey
# ---------------------------------------------------------
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-1.5-flash

# ---------------------------------------------------------
# OPCIÓN 2: Azure OpenAI
# Configura tu recurso en: https://portal.azure.com
# ---------------------------------------------------------
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-02-01

# ---------------------------------------------------------
# CONFIGURACIÓN DEL SERVIDOR
# ---------------------------------------------------------
APP_HOST=0.0.0.0
APP_PORT=8000
APP_ENV=development

# ---------------------------------------------------------
# CONFIGURACIÓN DEL VECTOR STORE (FAISS)
# ---------------------------------------------------------
VECTOR_STORE_PATH=./vector_store
EMBEDDINGS_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ---------------------------------------------------------
# CONFIGURACIÓN RAG
# ---------------------------------------------------------
RETRIEVAL_TOP_K=4
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ---------------------------------------------------------
# CORS - Orígenes permitidos (separados por coma)
# ---------------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080
